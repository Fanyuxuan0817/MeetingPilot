# MeetingPilot Environment Configuration
# Copy this file to .env and update the values

# Database (matches docker-compose.yml)
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/meetingpilot

# Application
APP_NAME=MeetingPilot API
DEBUG=false
SECRET_KEY=your-secret-key-change-in-production

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS=["*"]

# Vector Embedding
EMBEDDING_DIMENSION=1536
